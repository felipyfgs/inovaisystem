# Root environment file used by Docker Compose.
# Copy to `.env` and adjust as needed.

# Database
POSTGRES_DB=inovai
POSTGRES_USER=inovai
POSTGRES_PASSWORD=inovai
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=8000
APP_ENV=local
APP_DEBUG=true
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost

# Frontend (Nuxt)
FRONTEND_PORT=3000
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000
NUXT_PUBLIC_SANCTUM_BASE_URL=http://localhost:8000
